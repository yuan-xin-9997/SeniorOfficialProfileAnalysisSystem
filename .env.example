APP_ENV=dev
APP_NAME=Senior Official Profile Analysis System
APP_VERSION=0.1.0

# Local Docker Compose defaults. Replace these before any shared deployment.
POSTGRES_DB=sopa
POSTGRES_USER=sopa
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql+psycopg://sopa:change-me@postgres:5432/sopa
REDIS_URL=redis://redis:6379/0

JWT_SECRET=change-this-jwt-secret
ACCESS_TOKEN_EXPIRE_MINUTES=720

DEFAULT_CRAWL_CRON=0 3 * * 1
RAW_DOCS_DIR=/app/data/raw-docs

# LLM is disabled by default. Set provider and key when the parser milestone starts.
LLM_PROVIDER=disabled
LLM_API_KEY=
LLM_DAILY_LIMIT=200

# Initial admin is created only when the user table is empty.
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=change-me-admin-password

